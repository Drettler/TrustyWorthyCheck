{
  "manifest_version": 3,
  "name": "Is This Site Safe?",
  "version": "1.0.0",
  "description": "Instantly check if a website is trustworthy with one click",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Check this site"
  },
  "permissions": ["activeTab"]
}
